<controls:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Title="{Loc 'emag-comms-title'}"
    HeaderClass="DS14MenuHeader"
    TitleClass="DS14MenuTitle"
    MinSize="600 260"
    SetSize="600 260"
    Resizable="False">

    <PanelContainer StyleClasses="DS14MenuFlatBody"
                    HorizontalExpand="True"
                    VerticalExpand="True">
        <BoxContainer Name="PasswordView"
                      Access="Public"
                      Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalAlignment="Stretch"
                      SeparationOverride="6">
            <Label Name="PasswordTitle"
                   Access="Public"
                   Text="{Loc 'emag-comms-password-setup-title'}"
                   StyleClasses="DS14MenuProfileSection" />
            <RichTextLabel Name="PasswordHint"
                           Access="Public"
                           Text="{Loc 'emag-comms-password-setup-hint'}"
                           HorizontalExpand="True" />
            <LineEdit Name="PasswordInput"
                      Access="Public"
                      PlaceHolder="{Loc 'emag-comms-password-placeholder'}"
                      HorizontalExpand="True"
                      StyleClasses="DS14MenuInput" />
            <RichTextLabel Name="PasswordError"
                           Access="Public"
                           Visible="False"
                           ReservesSpace="False"
                           HorizontalExpand="True" />
            <Control VerticalExpand="True" />
            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <Button Name="PasswordReturnToNormalButton"
                       Access="Public"
                       Text="{Loc 'emag-comms-switch-normal'}"
                       MinWidth="180"
                       StyleClasses="DS14MenuProfileControl" />
                <Control HorizontalExpand="True" />
                <Button Name="PasswordConfirmButton"
                        Access="Public"
                        Text="{Loc 'emag-comms-password-confirm'}"
                        Disabled="True"
                        MinWidth="180"
                        StyleClasses="DS14MenuAction" />
            </BoxContainer>
        </BoxContainer>

        <BoxContainer Name="FormView"
                      Access="Public"
                      Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      SeparationOverride="6"
                      Visible="False">
            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <BoxContainer Orientation="Vertical"
                              HorizontalExpand="True"
                              SizeFlagsStretchRatio="1"
                              SeparationOverride="2">
                    <Label Text="{Loc 'emag-comms-announcer'}"
                           StyleClasses="DS14MenuProfileLabel" />
                    <LineEdit Name="AnnouncerInput"
                              Access="Public"
                              PlaceHolder="{Loc 'emag-comms-announcer-placeholder'}"
                              HorizontalExpand="True"
                              StyleClasses="DS14MenuInput" />
                </BoxContainer>
                <BoxContainer Orientation="Vertical"
                              HorizontalExpand="True"
                              SizeFlagsStretchRatio="1"
                              SeparationOverride="2">
                    <Label Text="{Loc 'emag-comms-signature'}"
                           StyleClasses="DS14MenuProfileLabel" />
                    <LineEdit Name="SignatureInput"
                              Access="Public"
                              PlaceHolder="{Loc 'emag-comms-signature-placeholder'}"
                              HorizontalExpand="True"
                              StyleClasses="DS14MenuInput" />
                </BoxContainer>
                <BoxContainer Orientation="Vertical"
                              HorizontalExpand="True"
                              SizeFlagsStretchRatio="0.7"
                              SeparationOverride="2">
                    <Label Text="{Loc 'emag-comms-color'}"
                           StyleClasses="DS14MenuProfileLabel" />
                    <BoxContainer Orientation="Horizontal"
                                  HorizontalExpand="True"
                                  SeparationOverride="4">
                        <Button Name="ColorPreview"
                                Access="Public"
                                Text=" "
                                MinSize="32 28"
                                SetSize="32 28"
                                StyleClasses="DS14MenuProfileControl" />
                        <LineEdit Name="ColorHexInput"
                                  Access="Public"
                                  Text="1d8bad"
                                  PlaceHolder="{Loc 'emag-comms-color-placeholder'}"
                                  HorizontalExpand="True"
                                  StyleClasses="DS14MenuInput" />
                    </BoxContainer>
                </BoxContainer>
            </BoxContainer>

            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True">
                <Label Text="{Loc 'emag-comms-announcement'}"
                       StyleClasses="DS14MenuProfileLabel" />
                <Control HorizontalExpand="True" />
                <Label Name="CharacterCounter"
                       Access="Public"
                       StyleClasses="DS14MenuSubtitle" />
            </BoxContainer>
            <PanelContainer StyleClasses="DS14MenuTextField"
                            HorizontalExpand="True"
                            VerticalExpand="True">
                <TextEdit Name="AnnouncementInput"
                          Access="Public"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          MinHeight="100"
                          StyleClasses="DS14MenuTextArea" />
            </PanelContainer>

            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <Label Text="{Loc 'emag-comms-sound'}"
                       MinWidth="72"
                       VerticalAlignment="Center"
                       StyleClasses="DS14MenuProfileLabel" />
                <OptionButton Name="SoundSelector"
                              Access="Public"
                              Filterable="True"
                              HorizontalExpand="True"
                              StyleClasses="DS14MenuProfileControl" />
                <Label Name="SoundDuration"
                       Access="Public"
                       Text="00:00"
                       MinWidth="42"
                       Align="Center"
                       VerticalAlignment="Center"
                       StyleClasses="DS14MenuSubtitle" />
                <Button Name="PreviewButton"
                        Access="Public"
                        Text="{Loc 'emag-comms-preview'}"
                        MinWidth="96"
                        StyleClasses="DS14MenuProfileControl" />
            </BoxContainer>

            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <CheckBox Name="EnableTtsCheckBox"
                          Access="Public"
                          Text="{Loc 'emag-comms-enable-tts'}"
                          Pressed="True"
                          StyleClasses="DS14MenuProfileControl" />
                <CheckBox Name="UseCustomTtsCheckBox"
                          Access="Public"
                          Text="{Loc 'emag-comms-custom-tts'}"
                          StyleClasses="DS14MenuProfileControl" />
                <Control HorizontalExpand="True" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              SizeFlagsStretchRatio="1"
                              SeparationOverride="4">
                    <Label Text="{Loc 'emag-comms-voice'}"
                           MinWidth="52"
                           VerticalAlignment="Center"
                           StyleClasses="DS14MenuProfileLabel" />
                    <OptionButton Name="VoiceSelector"
                                  Access="Public"
                                  Filterable="True"
                                  HorizontalExpand="True"
                                  Disabled="True"
                                  StyleClasses="DS14MenuProfileControl" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True"
                              SizeFlagsStretchRatio="1"
                              SeparationOverride="4">
                    <Label Text="{Loc 'emag-comms-language'}"
                           MinWidth="52"
                           VerticalAlignment="Center"
                           StyleClasses="DS14MenuProfileLabel" />
                    <OptionButton Name="LanguageSelector"
                                  Access="Public"
                                  Filterable="True"
                                  HorizontalExpand="True"
                                  StyleClasses="DS14MenuProfileControl" />
                </BoxContainer>
            </BoxContainer>

            <RichTextLabel Name="FormStatus"
                           Access="Public"
                           Visible="False"
                           ReservesSpace="False"
                           HorizontalExpand="True" />
            <BoxContainer Orientation="Horizontal"
                          HorizontalExpand="True"
                          SeparationOverride="6">
                <Button Name="ReturnToNormalButton"
                        Access="Public"
                        Text="{Loc 'emag-comms-switch-normal'}"
                        MinWidth="180"
                        StyleClasses="DS14MenuProfileControl" />
                <Control HorizontalExpand="True" />
                <Button Name="AnnounceButton"
                        Access="Public"
                        Text="{Loc 'emag-comms-announce'}"
                        Disabled="True"
                        MinWidth="180"
                        StyleClasses="DS14MenuAction" />
            </BoxContainer>
            <RichTextLabel Text="{Loc 'emag-comms-footer'}"
                           HorizontalExpand="True"
                           StyleClasses="DS14MenuSubtitle" />
        </BoxContainer>
    </PanelContainer>
</controls:FancyWindow>
